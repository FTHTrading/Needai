{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CallRail OS Number Configuration",
  "description": "Schema for phone number configuration in the CallRail OS system",
  "type": "object",
  "required": ["version", "numbers"],
  "properties": {
    "version": {
      "type": "string",
      "description": "Configuration version"
    },
    "lastUpdated": {
      "type": "string",
      "format": "date",
      "description": "Last update date (ISO 8601)"
    },
    "description": {
      "type": "string"
    },
    "numbers": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/number"
      }
    },
    "campaigns": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/definitions/campaign"
      }
    },
    "personas": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/definitions/persona"
      }
    }
  },
  "definitions": {
    "number": {
      "type": "object",
      "required": ["id", "vanity", "digits", "e164", "persona", "region", "type", "campaign", "active"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for this number"
        },
        "vanity": {
          "type": "string",
          "description": "Billboard-friendly vanity format (e.g., '470-STORM')"
        },
        "digits": {
          "type": "string",
          "pattern": "^[0-9]{10}$",
          "description": "10-digit number (digits only, no formatting)"
        },
        "e164": {
          "type": "string",
          "pattern": "^\\+1[0-9]{10}$",
          "description": "E.164 format with +1 prefix"
        },
        "persona": {
          "type": "string",
          "enum": ["STORM", "HAIL", "HVAC", "CLAIMS", "LAW", "MONEY", "NEED"],
          "description": "AI persona to route to"
        },
        "region": {
          "type": "string",
          "description": "Geographic region or 'National' for toll-free"
        },
        "type": {
          "type": "string",
          "enum": ["local", "toll-free"],
          "description": "Number type"
        },
        "campaign": {
          "type": "string",
          "description": "Marketing campaign name"
        },
        "active": {
          "type": "boolean",
          "description": "Whether this number is currently active"
        },
        "priority": {
          "type": "string",
          "enum": ["primary", "secondary", "tertiary"],
          "description": "Routing priority level"
        },
        "notes": {
          "type": "string",
          "description": "Optional notes about this number"
        }
      }
    },
    "campaign": {
      "type": "object",
      "required": ["name", "description", "count", "personas"],
      "properties": {
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "count": {
          "type": "integer",
          "minimum": 0
        },
        "personas": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "persona": {
      "type": "object",
      "required": ["name", "script", "capabilities"],
      "properties": {
        "name": {
          "type": "string"
        },
        "script": {
          "type": "string",
          "description": "Path to persona script file"
        },
        "capabilities": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
